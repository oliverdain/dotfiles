#!/bin/bash

podman run --rm -ti \
  -v $(pwd):/home/cmp/code \
  -w /home/cmp/code \
  -v ~/.claude:/home/cmp/.claude \
  -v ~/.claude.json:/home/cmp/.claude.json \
  -v ~/bin:/home/cmp/bin:ro \
  --userns=keep-id:uid=$(id -u),gid=$(id -g) \
  --entrypoint /home/cmp/.volta/bin/claude \
  us-west1-docker.pkg.dev/infra-88/main/claude:v1.0.0 --permission-mode=bypassPermissions
